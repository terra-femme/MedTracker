# ============================================================================
# MedTracker Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit it.
#
# USAGE:
#   cp .env.example .env
#   # Edit .env with your values
#   uvicorn main:app --reload
# ============================================================================


# ── Push Notifications (Web Push / VAPID) ────────────────────────────────────
# Generate keys ONCE and paste here. Changing these invalidates all existing
# browser subscriptions (users would need to re-enable in Settings).
#
# How to generate:
#   pip install pywebpush
#   python -c "
#   from py_vapid import Vapid
#   v = Vapid()
#   v.generate_keys()
#   print('Private key (PEM):')
#   print(v.private_pem().decode())
#   print('Public key (base64url):')
#   from base64 import urlsafe_b64encode
#   pub = v.public_key.public_bytes_raw()
#   print(urlsafe_b64encode(pub).decode().rstrip('='))
#   "
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:you@example.com


# ── Authentication (JWT) ─────────────────────────────────────────────────────
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Changing this invalidates all existing tokens (all users are logged out).
SECRET_KEY=change-this-secret-key-before-deploying


# ── Database ─────────────────────────────────────────────────────────────────
# Defaults to SQLite at ./medtracker.db if not set.
# Set this to a PostgreSQL URL when moving to production.
#DATABASE_URL=postgresql://user:password@localhost:5432/medtracker
